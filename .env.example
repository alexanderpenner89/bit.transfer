# ─── Ghost ────────────────────────────────────────────────────────────────────
# Settings → Integrations → Add custom integration → Copy Admin API Key
GHOST_ADMIN_API_KEY=
GHOST_URL=http://localhost:2368
GHOST_AI_AUTHOR_ID=   # filled by: python create-ai-author.py

# ─── MySQL ────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=ghostpass

# ─── LLM Provider ─────────────────────────────────────────────────────────────
PROVIDER=openrouter

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=
OLLAMA_MODEL=llama3.2

OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ─── Concurrency ──────────────────────────────────────────────────────────────
LLM_CONCURRENCY=3
OPENALEX_CONCURRENCY=1

# ─── Pipeline Tuning ──────────────────────────────────────────────────────────
# PERSPECTIVE_MAX_RELATED=8
# EXPANSION_TOP_N=10

# ─── DevTools CORS ────────────────────────────────────────────────────────────
# Comma-separated list. Default ["*"] allows all origins.
# CORS_ALLOWED_ORIGINS=["https://alexanderpenner.de"]

# ─── Langfuse ─────────────────────────────────────────────────────────────────
LANGFUSE_ENABLED=true
LANGFUSE_PUBLIC_KEY=pk-lf-
LANGFUSE_SECRET_KEY=sk-lf-
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ─── OpenAlex ─────────────────────────────────────────────────────────────────
OPENALEX_API_KEY=
# OPENALEX_PRECISION_SEARCH_DATE=2026-03-08
