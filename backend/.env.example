# Provider selection — choose one: anthropic | openai | gemini | ollama | openrouter
PROVIDER=ollama

# =============================================================================
# Anthropic
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# =============================================================================
# OpenAI
# =============================================================================
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# =============================================================================
# Gemini (Google)
# =============================================================================
GOOGLE_API_KEY=AIza-your-key-here
GEMINI_MODEL=gemini-2.5-pro

# =============================================================================
# Ollama — local (default) or cloud
# Local:  OLLAMA_BASE_URL=http://localhost:11434/v1  (no API key needed)
# Cloud:  OLLAMA_BASE_URL=https://ollama.com/v1      (API key required)
# =============================================================================
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=
OLLAMA_MODEL=llama3.2

# =============================================================================
# OpenRouter
# =============================================================================
OPENROUTER_API_KEY=sk-or-your-key-here
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# =============================================================================
# OpenAlex
# =============================================================================
OPENALEX_API_KEY=your-openalex-api-key-here

# =============================================================================
# Concurrency
# =============================================================================
# Max parallel LLM calls. Ollama Cloud allows 3 simultaneous requests.
# Increase for providers without strict concurrency limits (e.g. Anthropic: 10).
LLM_CONCURRENCY=3

# =============================================================================
# Langfuse Tracing (optional)
# =============================================================================
# Set LANGFUSE_ENABLED=false to disable tracing
LANGFUSE_ENABLED=true

# Get your keys from https://cloud.langfuse.com or use local instance
LANGFUSE_PUBLIC_KEY=pk-lf-your-key-here
LANGFUSE_SECRET_KEY=sk-lf-your-key-here

# For self-hosted Langfuse (via docker-compose.langfuse.yml):
# LANGFUSE_BASE_URL=http://localhost:3000
# For Langfuse Cloud (default):
LANGFUSE_BASE_URL=https://cloud.langfuse.com
