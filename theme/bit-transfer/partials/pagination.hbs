{{#if prev}}
<nav class="pagination" aria-label="Seitennavigation">
    {{#if prev}}
    <a href="{{page_url prev}}" class="pagination-prev" aria-label="Neuere Beiträge">← Neuere Beiträge</a>
    {{/if}}
    <span class="pagination-info">Seite {{page}} von {{pages}}</span>
    {{#if next}}
    <a href="{{page_url next}}" class="pagination-next" aria-label="Ältere Beiträge">Ältere Beiträge →</a>
    {{/if}}
</nav>
{{/if}}
