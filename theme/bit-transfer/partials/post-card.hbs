<article class="post-card {{post_class}}"
    data-tags="{{#foreach tags}}{{slug}} {{/foreach}}"
    data-primary-tag="{{primary_tag.slug}}"
    data-title="{{title}}">
    <a href="{{url}}" class="post-card-link">
        {{#if feature_image}}
        <div class="post-card-image">
            <img src="{{img_url feature_image size="md"}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}" loading="lazy">
        </div>
        {{/if}}
        <div class="post-card-content">
            <p class="post-card-tag">{{primary_tag.name}}</p>
            <h3 class="post-card-title">{{title}}</h3>
            {{#if excerpt}}
            <p class="post-card-excerpt">{{excerpt words="15"}}</p>
            {{else}}
            <p class="post-card-status">verfügbar</p>
            {{/if}}
        </div>
    </a>
</article>
