<!DOCTYPE html>
<html lang="de" class="{{body_class}}">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{meta_title}}</title>
    <link rel="canonical" href="{{canonical_url}}">
    {{ghost_head}}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,800;0,900;1,700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" type="text/css" href="{{asset "css/screen.css"}}">
</head>
<body class="{{body_class}}">

    {{> "navigation"}}

    <div class="site-wrapper">
        {{{body}}}
    </div>

    <footer class="site-footer">
        <div class="container">
            <div class="footer-inner">
                <div class="footer-brand">
                    <a href="{{@site.url}}" class="footer-logo">
                        <span class="logo-mark">bt</span>
                        <span class="logo-text">bit.transfer</span>
                    </a>
                    <p class="footer-tagline">{{@site.description}}</p>
                </div>
                <nav class="footer-nav">
                    {{#foreach @site.navigation}}
                    <a href="{{url}}">{{label}}</a>
                    {{/foreach}}
                </nav>
                <p class="footer-copy">&copy; {{date format="YYYY"}} bit.transfer</p>
            </div>
        </div>
    </footer>

    {{ghost_foot}}
    <script src="{{asset "js/app.js"}}"></script>
</body>
</html>
