{{!< default}}

<main class="site-main">
    <div class="container">
        <div class="content-layout">

            <article class="post-full page-full {{post_class}}">
                {{#post}}
                {{#if @page.show_title_and_feature_image}}
                <header class="post-header">
                    <h1 class="post-title">{{title}}</h1>
                    {{#if custom_excerpt}}
                    <p class="post-subtitle">{{custom_excerpt}}</p>
                    {{/if}}
                </header>

                {{#if feature_image}}
                <figure class="post-feature-image">
                    <img src="{{img_url feature_image size="lg"}}" alt="{{title}}">
                </figure>
                {{/if}}
                {{/if}}

                <section class="post-content gh-content">
                    {{content}}
                </section>
                {{/post}}
            </article>

            {{> "sidebar"}}

        </div>
    </div>
</main>
